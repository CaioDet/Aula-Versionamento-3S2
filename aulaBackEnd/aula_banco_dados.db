-- 1. Criando a tabela de Projetos (A tabela Principal)
CREATE TABLE Projetos (
    id_projeto INT PRIMARY KEY,
    nome_projeto VARCHAR(100),
    descricao VARCHAR(255)
);

-- 2. Criando a tabela de Tarefas (A tabela Dependente)
CREATE TABLE Tarefas (
    id_tarefa INT PRIMARY KEY,
    id_projeto INT, 
    descricao_tarefa VARCHAR(255),
    FOREIGN KEY (id_projeto) REFERENCES Projetos(id_projeto)
);


-- 3. Inserindo dados nos Projetos
INSERT INTO Projetos (id_projeto, nome_projeto, descricao)
VALUES 
(1, 'Novo Website', 'Desenvolvimento do novo site da empresa'),
(2, 'Aplicativo Mobile', 'App para Android e iOS');

-- 4. Inserindo dados nas Tarefas
-- Note que o id_projeto (1 ou 2) é o gancho que liga a tarefa ao projeto!
INSERT INTO Tarefas (id_tarefa, id_projeto, descricao_tarefa)
VALUES 
(1, 1, 'Design da interface'),
(2, 1, 'Desenvolvimento do backend'),
(3, 2, 'Criação do protótipo');


